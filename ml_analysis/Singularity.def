Bootstrap: docker
From: continuumio/miniconda3:24.9.2-0

%files
    environment.yml /app/environment.yml
    generate_fold_model.py /app/generate_fold_model.py
    helper /app/helper
    external /app/external
    slurm_scripts /app/slurm_scripts

%post
    set -e
    export TMPDIR=/root/build-tmp
    export PIP_CACHE_DIR=/root/pip-cache
    mkdir -p "$TMPDIR" "$PIP_CACHE_DIR"
    cd /app
    conda env create -f environment.yml
    conda clean -afy
    rm -rf /root/.cache/pip/
    rm -rf "$TMPDIR" "$PIP_CACHE_DIR"
    mkdir -p /in /out

%environment
    export PYTHONDONTWRITEBYTECODE=false

%runscript
    conda run --no-capture-output -n ml_analysis python /app/generate_fold_model.py "$@"
